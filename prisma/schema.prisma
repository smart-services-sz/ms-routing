generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model RoutingCategoryRule {
  id           String   @id @default(uuid()) @db.Uuid
  categoria    String   @unique
  cupoDiario   Int
  pesoPrioridad Int     @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model RoutingCrewRule {
  id                 String   @id @default(uuid()) @db.Uuid
  crewId             String   @unique
  nombre             String?
  maxReclamosDiarios Int
  allowedCategorias  String[]
  allowedZoneIds     String[]
  startLat           Float?
  startLng           Float?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model RoutingZoneRule {
  id        String   @id
  nombre    String?
  minLat    Float
  maxLat    Float
  minLng    Float
  maxLng    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RoutingAreaPlan {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  userId          String
  userName        String?
  categorias      String[]
  originAddress   String?
  originLat       Float
  originLng       Float
  dailyByUser     Int
  dailyByCategory Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([updatedAt])
}

model RoutingPlan {
  id           String            @id @default(uuid()) @db.Uuid
  planningDate DateTime
  status       String            @default("proposed")
  summary      Json
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  routes       RoutingRoute[]
  unassigned   RoutingUnassigned[]

  @@index([planningDate])
}

model RoutingRoute {
  id                 String        @id @default(uuid()) @db.Uuid
  planId             String        @db.Uuid
  crewId             String
  nombre             String
  status             String        @default("assigned")
  assignedAt         DateTime      @default(now())
  startedAt          DateTime?
  completedAt        DateTime?
  assignedClaims     Int
  maxReclamosDiarios Int
  totalDistanceKm    Float
  totalDurationMin   Int
  createdAt          DateTime      @default(now())
  plan               RoutingPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
  stops              RoutingStop[]
  interventions      RoutingIntervention[]

  @@index([planId])
}

model RoutingStop {
  id                      String       @id @default(uuid()) @db.Uuid
  routeId                 String       @db.Uuid
  sequence                Int
  status                  String       @default("pendiente")
  visitedAt               DateTime?
  reclamoId               String       @db.Uuid
  categoria               String
  prioridad               String
  zoneId                  String?
  lat                     Float
  lng                     Float
  direccion               String
  distanceFromPreviousKm  Float
  durationFromPreviousMin Int
  createdAt               DateTime     @default(now())
  route                   RoutingRoute @relation(fields: [routeId], references: [id], onDelete: Cascade)
  intervention            RoutingIntervention?

  @@index([routeId])
  @@index([reclamoId])
}

model RoutingIntervention {
  id          String                      @id @default(uuid()) @db.Uuid
  routeId     String                      @db.Uuid
  stopId      String                      @unique @db.Uuid
  reclamoId   String                      @db.Uuid
  result      String
  observation String?
  performedBy String?
  performedAt DateTime
  createdAt   DateTime                    @default(now())
  updatedAt   DateTime                    @updatedAt
  route       RoutingRoute                @relation(fields: [routeId], references: [id], onDelete: Cascade)
  stop        RoutingStop                 @relation(fields: [stopId], references: [id], onDelete: Cascade)
  evidences   RoutingInterventionEvidence[]

  @@index([routeId])
  @@index([reclamoId])
}

model RoutingInterventionEvidence {
  id             String              @id @default(uuid()) @db.Uuid
  interventionId String              @db.Uuid
  tipo           String
  nombreArchivo  String
  urlArchivo     String
  descripcion    String?
  createdAt      DateTime            @default(now())
  intervention   RoutingIntervention @relation(fields: [interventionId], references: [id], onDelete: Cascade)

  @@index([interventionId])
}

model RoutingUnassigned {
  id        String      @id @default(uuid()) @db.Uuid
  planId    String      @db.Uuid
  reclamoId String      @db.Uuid
  reason    String
  createdAt DateTime    @default(now())
  plan      RoutingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@index([planId])
}
